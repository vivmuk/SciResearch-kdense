## Required

# Venice AI API key — https://venice.ai/settings/api
VENICE_API_KEY=

# LLMs (use venice/<model-id> from the Venice model catalog)
DEFAULT_AGENT_MODEL="venice/minimax-m3"
DEFAULT_EXPERT_MODEL="venice/qwen3-5-9b"

## Optional: local Ollama server
OLLAMA_BASE_URL=http://localhost:11434

## Highly Recommended (Delete if not needed and filled in correctly)
EXA_API_KEY=
PARALLEL_API_KEY=
PAPERCLIP_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

## Optional Scientific APIs
NCBI_API_KEY=
NCBI_EMAIL=
S2_API_KEY=
CORE_API_KEY=
OPENALEX_API_KEY=
