## Required

# LLM API keys
# Only required if you plan to use OpenRouter-hosted models. If you are
# running everything locally through Ollama, this can be left blank.
OPENROUTER_API_KEY=

# Gemini CLI -> LiteLLM proxy -> OpenRouter
GOOGLE_GEMINI_BASE_URL=http://localhost:4000
GEMINI_API_KEY=sk-litellm-local

# LLMs
DEFAULT_AGENT_MODEL="openrouter/anthropic/claude-opus-4.7"
# Default model for the Gemini CLI expert subprocess (delegate_task). Any
# OpenRouter, Ollama, or gemini-* id works; routes through the LiteLLM
# proxy. Leave blank to use the built-in recommended default
# (openrouter/google/gemini-3.1-pro-preview) — Gemini 3.1 Pro's native tool
# calling and 1M-token context suit the CLI expert better than the
# orchestrator's Claude Opus default.
DEFAULT_EXPERT_MODEL="openrouter/google/gemini-3.1-pro-preview"


## Optional: local Ollama server

# Host for a running `ollama serve`. Models pulled into Ollama show up
# automatically in the model dropdown and route through the LiteLLM
# proxy's `ollama/*` wildcard entry (see litellm_config.yaml).
OLLAMA_BASE_URL=http://localhost:11434


## Highly Recommended (Delete if not needed and filled in correctly)

# Exa Search (get your key at https://dashboard.exa.ai/api-keys)
EXA_API_KEY=

# Parallel Search
PARALLEL_API_KEY=

# Paperclip literature, regulatory, and clinical-trial MCP
PAPERCLIP_API_KEY=

# Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=


